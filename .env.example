# Copiar este archivo como .env y completar los valores reales.
# El archivo .env NO se commitea (agregarlo a .gitignore).

# ── Base de datos ─────────────────────────────────────────────────────────────
# Ambiente de testeo: OlympusDB_QA  |  Producción: OlympusDB
DB_SERVER=142.93.50.164
DB_NAME=OlympusDB_QA
DB_USER=GrowthArg
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server

# DB desde donde se lee el catálogo de productos (read-only).
# En testing conviene apuntar a OlympusDB para usar el catálogo real
# sin sincronizar QA. En producción, dejar igual a DB_NAME.
PRODUCTS_DB_NAME=OlympusDB

# ── Autenticación ─────────────────────────────────────────────────────────────
# Clave compartida con el plugin de WordPress. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
WORDPRESS_API_KEY=

# ── Servidor ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ── CORS ─────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Vacío = no CORS (plugin server-to-server).
# Ej: CORS_ORIGINS=https://miwordpress.com,https://www.miwordpress.com
CORS_ORIGINS=
